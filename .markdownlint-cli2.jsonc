{
  "globs": [
    "**/*.md",
    "!node_modules/**",
    "!.next/**"
  ],
  "config": {
    "MD013": false,
    "MD024": {
      "siblings_only": true,
      "allow_different_nesting": true
    },
    "MD060": false,
    "MD033": {
      "allowed_elements": ["p", "h1", "img", "a", "br", "code"]
    },
    "MD041": false
  }
}
